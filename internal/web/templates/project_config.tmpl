{{define "content"}}
<div id="page-project-config">
{{template "project_config_header" $}}

<div class="section card" id="project-policy">
  <h2>Team policy</h2>
  <p class="sub" style="margin-top:0">
    What Grok does for members without an explicit role. Explicit roles on the
    roster below always apply. Changes save immediately, including for
    already-queued tasks.
  </p>
  <form method="post" action="{{route "config.setProjectSafeTeam"}}">
    {{template "csrf" $}}
    <input type="hidden" name="name" value="{{.ProjectItem.Name}}">
    <div class="choice-row">
      <label class="choice">
        <input type="radio" name="safeTeamMode" value="0" {{if not .ProjectItem.SafeTeamMode}}checked{{end}} data-autosubmit>
        <span class="dot"></span>
        <span class="t">Trusted team <span class="flag ok">simple</span></span>
        <span class="d">Members without a role act as <span class="mono">builder</span> — investigate, run sessions, push &amp; open PRs.</span>
      </label>
      <label class="choice">
        <input type="radio" name="safeTeamMode" value="1" {{if .ProjectItem.SafeTeamMode}}checked{{end}} data-autosubmit>
        <span class="dot"></span>
        <span class="t">Role-based <span class="flag warn">safe team</span></span>
        <span class="d">Members without a role fall back to the default role below — normally <span class="mono">investigator</span> (no PRs / no ship).</span>
      </label>
    </div>
    {{if .ProjectItem.SafeTeamMode}}
    <div class="choice-extra">
      <label for="safe-team-default-tpl">Default role for members without one</label>
      <select id="safe-team-default-tpl" name="safeTeamDefaultTemplate" data-autosubmit>
        {{$curTpl := .ProjectItem.SafeTeamDefaultTemplate}}
        {{range .ProjectItem.CapabilityTemplateNames}}
        <option value="{{.}}" {{if eq . $curTpl}}selected{{end}}>{{.}}</option>
        {{end}}
      </select>
      <span class="muted" style="font-size:0.75rem">Assign eng members <span class="mono">builder</span> below so they can still ship.</span>
    </div>
    {{else}}
    <input type="hidden" name="safeTeamDefaultTemplate" value="{{.ProjectItem.SafeTeamDefaultTemplate}}">
    {{end}}
    <noscript><div class="form-actions"><button type="submit">Save policy</button></div></noscript>
  </form>
</div>

<div class="section card" id="project-members">
  <h2>Members</h2>
  <p class="sub" style="margin-top:0">
    Who can <span class="mono">@Grok</span> on this project’s channels, and their role.
    Role changes save immediately. Web UI visibility follows user entries; Discord roles apply in chat only.
  </p>
  {{if not .ProjectItem.AllowedUserIDs}}{{if not .ProjectItem.AllowedRoleIDs}}
  <div class="flash err" style="margin-bottom:0.85rem;">No members — add at least one user or role or nobody can use Grok on this project (fail-closed).</div>
  {{end}}{{end}}

  {{if .Members}}
  <div class="roster" id="member-roster">
    <div class="roster-head">
      <span>Member</span><span>Role</span><span>Can do</span><span></span>
    </div>
    {{range .Members}}
    <div class="roster-row{{if .Inert}} attention{{end}}">
      <span class="who">
        <span class="avatar{{if .IsRole}} role-badge{{end}}">{{.Initials}}</span>
        <span class="id-wrap">
          <span class="name">{{if .Name}}{{.Name}}{{else}}<span class="mono">{{.ID}}</span>{{end}}{{if .IsRole}}<span class="kind-tag">role</span>{{end}}</span>
          {{if .Name}}<span class="snowflake">{{.ID}}</span>{{else if .Inert}}<span class="snowflake">not on member list</span>{{end}}
        </span>
      </span>
      <span class="role-cell">
        <form method="post" action="{{if .IsRole}}{{route "config.setProjectCapabilityRole"}}{{else}}{{route "config.setProjectCapabilityUser"}}{{end}}">
          {{template "csrf" $}}
          <input type="hidden" name="name" value="{{$.ProjectItem.Name}}">
          <input type="hidden" name="id" value="{{.ID}}">
          <select name="template" data-autosubmit {{if not .Explicit}}class="is-default"{{end}} aria-label="Role for {{.ID}}">
            <option value="" {{if not .Explicit}}selected{{end}}>default → {{$.DefaultRoleFallback}}</option>
            {{$row := .}}
            {{range $.ProjectItem.CapabilityTemplateNames}}
            <option value="{{.}}" {{if eq . $row.Template}}selected{{end}}>{{.}}</option>
            {{end}}
            {{if .TemplateUnknown}}<option value="{{.Template}}" selected>{{.Template}} (unknown)</option>{{end}}
          </select>
          <noscript><button type="submit" class="btn-secondary" style="height:2.1rem;font-size:0.78rem;margin-top:0.3rem;">Set</button></noscript>
        </form>
      </span>
      {{if .Inert}}
      <span class="attention-note">⚠ has a role but no membership — cannot use Grok.
        <form method="post" action="{{if .IsRole}}{{route "config.addProjectRole"}}{{else}}{{route "config.addProjectUser"}}{{end}}">
          {{template "csrf" $}}
          <input type="hidden" name="name" value="{{$.ProjectItem.Name}}">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit">Add as member</button>
        </form>
      </span>
      {{else}}
      <span class="caps">
        {{$row := .}}
        {{range .Caps}}<span class="cap{{if eq . "admin"}} danger-cap{{else if and $row.Explicit (not $row.TemplateUnknown)}} hi{{end}}">{{.}}</span>{{end}}
      </span>
      {{end}}
      {{if .Inert}}
      <form class="row-x-form" method="post" action="{{if .IsRole}}{{route "config.removeProjectCapabilityRole"}}{{else}}{{route "config.removeProjectCapabilityUser"}}{{end}}" onsubmit="return confirm('Remove role assignment for {{.ID}}?');">
        {{template "csrf" $}}
        <input type="hidden" name="name" value="{{$.ProjectItem.Name}}">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" class="row-x" title="Remove role assignment">×</button>
      </form>
      {{else}}
      <form class="row-x-form" method="post" action="{{if .IsRole}}{{route "config.removeProjectRole"}}{{else}}{{route "config.removeProjectUser"}}{{end}}" onsubmit="return confirm('Remove {{if .IsRole}}role{{else}}user{{end}} {{.ID}} from this project?');">
        {{template "csrf" $}}
        <input type="hidden" name="name" value="{{$.ProjectItem.Name}}">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" class="row-x" title="Remove member">×</button>
      </form>
      {{end}}
    </div>
    {{end}}
  </div>
  {{end}}

  <form class="inline" method="post" action="{{route "config.addProjectMember"}}" style="grid-template-columns: 7rem 1fr 11rem auto; margin-top:0.85rem;">
    {{template "csrf" $}}
    <input type="hidden" name="name" value="{{.ProjectItem.Name}}">
    <div>
      <label for="member-kind">Type</label>
      <select id="member-kind" name="kind">
        <option value="user">User</option>
        <option value="role">Role</option>
      </select>
    </div>
    <div>
      <label for="member-id">Discord ID</label>
      <input id="member-id" type="text" name="id" placeholder="user or role snowflake" required autocomplete="off">
    </div>
    <div>
      <label for="member-tpl">Role</label>
      <select id="member-tpl" name="template">
        <option value="">default → {{.DefaultRoleFallback}}</option>
        {{range .ProjectItem.CapabilityTemplateNames}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </div>
    <button type="submit">Add member</button>
  </form>

  <details class="cap-matrix-details">
    <summary>What each role can do</summary>
    <div class="table-scroll">
      <table class="cap-matrix">
        <thead>
          <tr><th>role</th>{{range .CapNames}}<th>{{.}}</th>{{end}}</tr>
        </thead>
        <tbody>
          {{range .CapMatrix}}
          <tr><td class="mono">{{.Name}}</td>{{range .Flags}}<td class="{{if .}}dot-y{{else}}dot-n{{end}}">{{if .}}●{{else}}·{{end}}</td>{{end}}</tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </details>
</div>
</div>
{{end}}
