{{define "content"}}
<div class="config-sub" id="page-config-project-new">
{{template "config_sub_header" $}}
<h1>Add project</h1>
<p class="sub">
  Each project has its own settings page (GitHub repos, Discord, Linear, channel map) — adding one takes you straight there.
</p>
<div class="section card" id="projects">
  <form class="inline" method="post" action="{{route "config.addProject"}}">
    {{template "csrf" $}}
    <div>
      <label for="proj-name">Name</label>
      <input id="proj-name" type="text" name="name" placeholder="myapp" required autocomplete="off">
    </div>
    <div>
      <label for="proj-path">Absolute path</label>
      <input id="proj-path" type="text" name="path" placeholder="/absolute/path/to/repo" required autocomplete="off">
    </div>
    <button type="submit">Add folder</button>
  </form>
</div>
</div>
{{end}}
