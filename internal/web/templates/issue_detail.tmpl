{{define "content"}}
{{$open := eq .Issue.State "open" "OPEN"}}
<p class="pr-crumb">
  <a href="/projects/{{.Project}}/issues?owner={{urlquery .ActiveOwner}}&amp;repo={{urlquery .ActiveRepo}}">← Issues</a>
  <span class="crumb-sep">/</span>
  <span class="mono">{{.ActiveOwner}}/{{.ActiveRepo}}#{{.Issue.Number}}</span>
</p>
<div class="pr-title-row">
  <h1 id="page-issue-detail">{{if .Issue.Title}}{{.Issue.Title}}{{else}}{{.ActiveOwner}}/{{.ActiveRepo}}#{{.Issue.Number}}{{end}}</h1>
  <div class="pr-head-links">
    {{if .Issue.URL}}<a class="btn btn-compact" href="{{.Issue.URL}}" target="_blank" rel="noopener">GitHub ↗</a>{{end}}
  </div>
</div>
<div class="pr-meta">
  {{if eq .Issue.WorkState "FIXING"}}
  <span class="badge status-fixing" title="Active Grok fix session">FIXING</span>
  {{else if $open}}
  <span class="badge live">{{.Issue.State}}</span>
  {{else if .Issue.State}}
  <span class="badge">{{.Issue.State}}</span>
  {{end}}
  {{if .Issue.Author}}<span class="mono">{{.Issue.Author}}</span>{{end}}
  {{range .Issue.Labels}}<span class="badge">{{.}}</span>{{end}}
  {{if .Issue.Truncated}}<span class="muted">body truncated</span>{{end}}
</div>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="pr-cols">
<div class="pr-main">

<div class="section card">
  <h2>Description</h2>
  {{if .Issue.Body}}<div class="md">{{markdown .Issue.Body}}</div>{{else}}<p class="muted" style="margin:0">No description.</p>{{end}}
</div>

{{if .Issue.LinkedPRs}}
<div class="section card" id="issue-linked-prs">
  <h2>Related PRs <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Issue.LinkedPRs}})</span></h2>
  <p class="sub" style="margin:0 0 0.75rem">Pull requests linked as closing references (GitHub Development).</p>
  <div class="table-scroll">
  <table>
    <thead><tr><th>#</th><th>Title</th><th>State</th><th>Repo</th></tr></thead>
    <tbody>
    {{range .Issue.LinkedPRs}}
      <tr>
        <td class="mono">
          {{if and .Owner .Repo .Number}}
          <a href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">#{{.Number}}</a>
          {{else}}
          #{{.Number}}
          {{end}}
          {{if .URL}} <a href="{{.URL}}" target="_blank" rel="noopener" title="Open on GitHub">↗</a>{{end}}
        </td>
        <td>
          {{if and .Owner .Repo .Number}}
          <a class="pr-title" href="/prs/{{.Owner}}/{{.Repo}}/{{.Number}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{if .Title}}{{.Title}}{{else}}#{{.Number}}{{end}}</a>
          {{else if .Title}}{{.Title}}{{else}}<span class="muted">—</span>{{end}}
        </td>
        <td>
          {{if eq .State "OPEN"}}
          <span class="badge live">{{.State}}</span>
          {{else if eq .State "MERGED"}}
          <span class="badge status-merged">{{.State}}</span>
          {{else if eq .State "CLOSED"}}
          <span class="badge status-cancelled">{{.State}}</span>
          {{else if .State}}
          <span class="badge">{{.State}}</span>
          {{else}}
          <span class="muted">—</span>
          {{end}}
          {{if .IsDraft}} <span class="badge">draft</span>{{end}}
        </td>
        <td class="mono muted">{{if and .Owner .Repo}}{{.Owner}}/{{.Repo}}{{else}}—{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
</div>
{{end}}

<div class="section">
  <h2>Comments <span class="muted" style="font-weight:500;font-size:0.9rem">({{len .Issue.Comments}})</span></h2>
  {{range .Issue.Comments}}
  <div class="card" style="margin-bottom:0.75rem;">
    <div class="muted mono" style="font-size:0.85rem;">{{.Author}}</div>
    {{if .Body}}<div class="md" style="margin-top:0.5rem">{{markdown .Body}}</div>{{end}}
  </div>
  {{else}}
  <div class="empty">No comments.</div>
  {{end}}
</div>

</div>{{/* /pr-main */}}

<aside class="pr-rail">

{{if .CanStartSession}}
<div class="rail-group" id="issue-fix-form">
  <div class="rail-group-title">Grok</div>
  {{if .ShowFixPicker}}
  <p class="rail-note">Multiple sessions bind this issue — continue one:</p>
  {{range .FixHits}}
  <div class="grok-pick">
    <div class="grok-pick-head">
      <span class="badge">{{.Label}}</span>
      {{if .Busy}}<span class="badge live">busy</span>{{end}}
      <a class="tid mono" href="/sessions/{{.ThreadID}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{.ThreadID}}</a>
    </div>
    {{if .Goal}}<div class="grok-pick-goal">{{.Goal}}</div>{{end}}
    <form method="post" action="/projects/{{$.Project}}/issues/{{$.Issue.Number}}/fix" class="grok-pick-actions">
      {{template "csrf" $}}
      <input type="hidden" name="owner" value="{{$.ActiveOwner}}">
      <input type="hidden" name="repo" value="{{$.ActiveRepo}}">
      <input type="hidden" name="thread_id" value="{{.ThreadID}}">
      <button type="submit" class="btn-secondary btn-compact">Continue</button>
    </form>
  </div>
  {{else}}
  <p class="rail-note">No candidates (they may be terminal).</p>
  {{end}}
  <p class="rail-note">Or dispatch a fresh thread:</p>
  {{end}}
  <form method="post" action="/projects/{{.Project}}/issues/{{.Issue.Number}}/fix" class="grok-dispatch">
    {{template "csrf" $}}
    <input type="hidden" name="owner" value="{{.ActiveOwner}}">
    <input type="hidden" name="repo" value="{{.ActiveRepo}}">
    {{if .ShowFixPicker}}
    <input type="hidden" name="force_new" value="1">
    {{else}}
    <label class="check"><input type="checkbox" name="force_new" value="1"> Always start a new thread</label>
    {{end}}
    <div class="form-actions"><button type="submit" id="btn-fix-github">Fix with Grok</button></div>
  </form>
  <p class="rail-note">Starts or reuses a Discord work unit (Fixes bind). Grok opens/updates a PR; it never merges.</p>
</div>
{{end}}

{{if .CanGitHubWrite}}
<div class="rail-group" id="issue-comment-form">
  <div class="rail-group-title">GitHub</div>
  <details class="action">
    <summary><span class="action-title">Add comment</span></summary>
    <div class="action-body">
      <form method="post" action="/projects/{{.Project}}/issues/{{.Issue.Number}}/comments">
        {{template "csrf" $}}
        <input type="hidden" name="owner" value="{{.ActiveOwner}}">
        <input type="hidden" name="repo" value="{{.ActiveRepo}}">
        <div class="field">
          <label for="issue-body">Comment</label>
          <textarea id="issue-body" name="body" rows="4" required placeholder="Write a comment…"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit">Post comment</button>
          {{if $open}}
          <button type="submit" class="btn-danger" id="btn-issue-close"
            formaction="/projects/{{.Project}}/issues/{{.Issue.Number}}/close"
            onclick="return confirm('Post this comment and close the issue?');">Post comment &amp; close</button>
          {{end}}
        </div>
      </form>
    </div>
  </details>
</div>
{{end}}

{{if not (or .CanStartSession .CanGitHubWrite)}}
<div class="rail-group">
  <div class="rail-group-title">Actions</div>
  <p class="rail-note">Read-only access — Grok dispatch and GitHub writes need a member role with web features enabled.</p>
</div>
{{end}}

</aside>
</div>{{/* /pr-cols */}}
{{end}}
