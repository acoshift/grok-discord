{{define "content"}}
<p class="pr-crumb">
  <a href="/projects/{{.Project}}/commits?owner={{urlquery .ActiveOwner}}&amp;repo={{urlquery .ActiveRepo}}">← Commits</a>
  <span class="crumb-sep">/</span>
  <span class="mono">{{.ActiveOwner}}/{{.ActiveRepo}}{{if .Commit.ShortSHA}} @ {{.Commit.ShortSHA}}{{end}}</span>
</p>
<div class="pr-title-row">
  <h1 id="page-commit-detail">{{if .Commit.Subject}}{{.Commit.Subject}}{{else if .Commit.ShortSHA}}{{.Commit.ShortSHA}}{{else}}commit{{end}}</h1>
</div>
{{if .Commit.SHA}}
<div class="pr-meta">
  <span class="mono" title="{{.Commit.SHA}}">{{.Commit.SHA}}</span>
  {{if .Commit.AuthorName}}<span>{{.Commit.AuthorName}}{{if .Commit.AuthorEmail}} <span class="mono">&lt;{{.Commit.AuthorEmail}}&gt;</span>{{end}}</span>{{end}}
  {{if not .Commit.AuthorDate.IsZero}}<span class="mono">{{.Commit.AuthorDate.Format "2006-01-02 15:04 MST"}}</span>{{end}}
  {{with .DiffReview}}<span class="mono">{{if .TotalAdds}}<span class="diff-add">+{{.TotalAdds}}</span> {{end}}{{if .TotalDels}}<span class="diff-del">−{{.TotalDels}}</span> · {{end}}{{len .Files}} files</span>{{end}}
</div>
{{end}}
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

{{if .Commit.SHA}}
<div class="pr-cols">
<div class="pr-main">

<div class="section card">
  <h2>Message</h2>
  {{if .Commit.Body}}
  <pre class="bubble-body" style="margin:0;white-space:pre-wrap;">{{.Commit.Body}}</pre>
  {{else}}
  <p class="muted" style="margin:0">No extended message.</p>
  {{end}}
</div>

</div>{{/* /pr-main */}}

<aside class="pr-rail">

<div class="rail-group" id="commit-review-actions">
  <div class="rail-group-title">Grok</div>
  {{if .CanReviewCommit}}
  <form method="post" action="/projects/{{.Project}}/commits/{{.Commit.SHA}}/review" class="grok-dispatch" hx-boost="false">
    {{template "csrf" .}}
    <input type="hidden" name="owner" value="{{.ActiveOwner}}">
    <input type="hidden" name="repo" value="{{.ActiveRepo}}">
    <div class="form-actions"><button type="submit">Review in new session</button></div>
  </form>
  <p class="rail-note">Starts a new Discord thread (or web session) so Grok can review this commit with full tools and open GitHub issues agentically — labels, commit links, related refs.</p>
  {{else}}
  <p class="rail-note">Requires member role with <span class="mono">startSessions</span> enabled.</p>
  {{end}}
</div>

</aside>
</div>{{/* /pr-cols */}}

<div class="section">
  {{template "diff_review" .}}
</div>
{{end}}
{{end}}
