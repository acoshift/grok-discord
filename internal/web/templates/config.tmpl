{{define "content"}}
<div class="config-page" id="page-config">
<h1>Config</h1>
<p class="sub">Global bot &amp; runtime settings — each row opens a focused page. Changes persist to the config file and apply immediately. Per-project settings (members, workflow, integrations) live inside each project.</p>

{{if .Flash}}
<div class="flash">{{.Flash}}</div>
{{end}}
{{if .Error}}
<div class="flash err">{{.Error}}</div>
{{end}}

<div class="cfg-hub">
  <div class="cfg-hub-col">
    <div class="drill-cap">Bot</div>
    <div class="drill-group">
      <a class="drill" href="{{route "config.bot"}}">
        <span class="drill-main">
          <span class="drill-t">Discord bot</span>
          <span class="drill-s">install / re-authorize · default guild</span>
        </span>
        {{if .Config.InviteURL}}<span class="drill-v">ready</span>{{else}}<span class="badge status-warn">setup needed</span>{{end}}
      </a>
      <a class="drill" href="{{route "config.channels"}}">
        <span class="drill-main">
          <span class="drill-t">Channel map</span>
          <span class="drill-s">Discord channel → project routing</span>
        </span>
        <span class="drill-v">{{len .Config.Channels}} channel{{if ne (len .Config.Channels) 1}}s{{end}}</span>
      </a>
      <a class="drill" href="{{route "config.identities"}}">
        <span class="drill-main">
          <span class="drill-t">GitHub attribution</span>
          <span class="drill-s">Discord user → GitHub login map</span>
        </span>
        <span class="drill-v">{{len .Config.GitHubIdentities}} mapped</span>
      </a>
    </div>

    <div class="drill-cap">Grok runtime</div>
    <div class="drill-group">
      <a class="drill" href="{{route "config.run"}}">
        <span class="drill-main">
          <span class="drill-t">Run limits</span>
          <span class="drill-s">turn budget &amp; timeout per Discord task</span>
        </span>
        <span class="drill-v">{{.Config.MaxTurns}} turns · {{msDur .Config.TimeoutMs}}</span>
      </a>
      <div class="drill">
        <span class="drill-main">
          <span class="drill-t">Crash-safe active runs</span>
          <span class="drill-s">persist &amp; auto-resume after restart</span>
        </span>
        {{/* Pure boolean — toggles in place, no drill-in page. */}}
        <form method="post" action="{{route "config.resume"}}" class="drill-toggle">
          {{template "csrf" $}}
          <label class="switch" title="Resume active runs after restart">
            <input type="checkbox" name="resumeActiveRuns" value="1" {{if .Config.ResumeActiveRuns}}checked{{end}} data-autosubmit>
            <span class="knob" aria-hidden="true"></span>
            <span class="sr-only">Resume active runs after restart</span>
          </label>
        </form>
      </div>
      <a class="drill" href="{{route "config.risky"}}">
        <span class="drill-main">
          <span class="drill-t">Completion risk paths</span>
          <span class="drill-s">globs flagged on completion cards</span>
        </span>
        <span class="drill-v">{{if .Config.RiskyPathUseDefault}}defaults{{else}}custom{{end}}</span>
      </a>
    </div>
  </div>

  <div class="cfg-hub-col">
    <div class="drill-cap">Automation</div>
    <div class="drill-group">
      <a class="drill" href="{{route "config.board"}}">
        <span class="drill-main">
          <span class="drill-t">Team activity board</span>
          <span class="drill-s">/board grouping · nightly digest</span>
        </span>
        <span class="drill-v">stale {{.Config.BoardStaleDays}}d{{if .Config.BoardDigestChannel}} · digest on{{end}}</span>
      </a>
      <a class="drill" href="{{route "config.ci"}}">
        <span class="drill-main">
          <span class="drill-t">CI triage</span>
          <span class="drill-s">auto-queue /fix-ci on failing checks</span>
        </span>
        <span class="drill-v">{{if .Config.AutoFixCI}}on · max {{.Config.AutoFixCIMax}}{{else}}manual{{end}}</span>
      </a>
      <a class="drill" href="{{route "config.prlinks"}}">
        <span class="drill-main">
          <span class="drill-t">Discord PR links</span>
          <span class="drill-s">link target in bot messages</span>
        </span>
        <span class="drill-v">{{if eq .Config.DiscordPRLink "web"}}web UI{{else}}GitHub{{end}}</span>
      </a>
    </div>

    <div class="drill-cap">Worktrees</div>
    <div class="drill-group">
      <a class="drill" href="{{route "config.worktrees"}}">
        <span class="drill-main">
          <span class="drill-t">Folder &amp; idle cleanup</span>
          <span class="drill-s mono">{{.Config.WorktreesRoot}}</span>
        </span>
        <span class="drill-v">{{if .Config.WorktreeIdleTTLDays}}TTL {{.Config.WorktreeIdleTTLDays}}d{{else}}TTL off{{end}}</span>
      </a>
    </div>
  </div>
</div>

{{/* hx-target/hx-select override shell boost (#live-root) so SSE partials swap into the region, not wipe the page. */}}
<div class="live-region"
     id="live-config-lists"
     hx-get="{{route "partial.config.lists"}}"
     hx-trigger="sse:config"
     hx-target="this"
     hx-select="unset"
     hx-swap="innerHTML"
     hx-sync="this:queue last">
  {{template "config_lists" .}}
</div>

<p class="sub" id="access">Members are configured per project (open a project’s Settings). A project with no members is fail-closed — nobody can <span class="mono">@Grok</span> on its channels.</p>
</div>
{{end}}

{{define "config_lists"}}
<div class="section">
  <div class="drill-cap" style="display:flex;justify-content:space-between;align-items:baseline">Projects <a href="{{route "config.projectNew"}}" style="text-transform:none;letter-spacing:0;font-weight:550">+ Add project</a></div>
  {{if .Config.Projects}}
  <div class="drill-group">
    {{range .Config.Projects}}
    <a class="drill" href="/config/projects/{{.Name}}">
      <span class="proj-mark" aria-hidden="true">{{printf "%.1s" .Name}}</span>
      <span class="drill-main">
        <span class="drill-t">{{.Name}}</span>
        <span class="drill-s mono">{{.Path}}</span>
      </span>
      <span class="drill-v">
        {{$mu := len .AllowedUserIDs}}{{$mr := len .AllowedRoleIDs}}
        {{if or $mu $mr}}{{add $mu $mr}} member{{if ne (add $mu $mr) 1}}s{{end}}{{else}}no members{{end}}
        · {{if .ChannelOptions}}{{len .ChannelOptions}} ch{{else}}no ch{{end}}
      </span>
      {{if not (or (len .AllowedUserIDs) (len .AllowedRoleIDs))}}<span class="badge status-warn">fail-closed</span>{{end}}
    </a>
    {{end}}
  </div>
  {{else}}
  <div class="empty">No projects configured. <a href="{{route "config.projectNew"}}">Add the first one.</a></div>
  {{end}}
</div>
{{end}}
