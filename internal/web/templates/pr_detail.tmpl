{{define "content"}}
<p class="sub" style="margin-bottom:0.5rem"><a href="{{if .Project}}/projects/{{.Project}}/ship{{else}}{{route "ship"}}{{end}}">← Ship board</a></p>
<h1 id="page-pr-detail">{{.ActiveOwner}}/{{.ActiveRepo}}#{{.PRNumber}}</h1>
<p class="sub">
  <a href="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/diff{{if .Project}}?project={{urlquery .Project}}{{end}}">View diff</a>
  {{if .PR.URL}} · <a href="{{.PR.URL}}" target="_blank" rel="noopener">Open on GitHub ↗</a>{{end}}
</p>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="section card">
  <h2>{{.PR.Title}}</h2>
  <p class="sub" style="margin:0">
    {{if eq .PR.State "OPEN"}}<span class="badge live">{{.PR.State}}</span>{{else if eq .PR.State "MERGED"}}<span class="badge status-merged">{{.PR.State}}</span>{{else if eq .PR.State "CLOSED"}}<span class="badge status-cancelled">{{.PR.State}}</span>{{else}}<span class="badge">{{.PR.State}}</span>{{end}}
    {{if .PR.IsDraft}} <span class="badge">draft</span>{{end}}
    · review <span class="mono">{{.PR.ReviewDecision}}</span>
    · checks <span class="mono">{{.PR.Checks}}</span>
    · mergeable <span class="mono">{{.PR.Mergeable}}</span>
  </p>
  <p class="sub" style="margin:0.45rem 0 0">
    <span class="mono">{{.PR.Author}}</span>
    · <span class="mono">{{.PR.HeadRef}} → {{.PR.BaseRef}}</span>
    · <span class="mono" style="color:var(--ok)">+{{.PR.Additions}}</span>/<span class="mono" style="color:var(--danger)">−{{.PR.Deletions}}</span> · {{.PR.ChangedFiles}} files
  </p>
  <pre class="bubble-body" style="margin-top:1rem;white-space:pre-wrap;">{{.PR.Body}}</pre>
</div>

<div class="section card" id="pr-team-review">
  <div class="team-review-head">
    <h2>Team review</h2>
    <div class="team-review-status">
      {{if .TeamRollupText}}
      <span class="badge{{if .TeamRollupBadge}} {{.TeamRollupBadge}}{{end}}">{{.TeamRollupText}}</span>
      {{end}}
      {{if .PR.ReviewDecision}}
      <span class="muted team-review-gh">GH <span class="mono">{{.PR.ReviewDecision}}</span></span>
      {{end}}
    </div>
  </div>
  <p class="sub team-review-blurb">Discord-attributed team process. Does not satisfy GitHub branch protection.</p>

  {{if .TeamReviews}}
  <div class="table-scroll team-review-history">
  <table>
    <thead>
      <tr>
        <th>When</th>
        <th>Reviewer</th>
        <th>Verdict</th>
        <th>Commit</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody>
    {{range .TeamReviews}}
      <tr>
        <td class="mono nowrap">{{.Review.At.UTC.Format "2006-01-02 15:04"}}</td>
        <td>{{if .Review.ReviewerName}}{{.Review.ReviewerName}}{{else}}<span class="mono">{{.Review.ReviewerID}}</span>{{end}}</td>
        <td class="team-review-verdict">
          <span class="badge{{if .BadgeClass}} {{.BadgeClass}}{{end}}">{{.LabelText}}</span>
          {{if .Fresh}}
          <span class="badge live">fresh</span>
          {{else if .StickyCR}}
          <span class="badge status-error" title="Still blocking until this reviewer re-reviews">blocking</span>
          {{else}}
          <span class="badge">stale</span>
          {{end}}
        </td>
        <td class="mono" title="{{.Review.HeadSHA}}">{{if .HeadShort}}{{.HeadShort}}{{else}}—{{end}}</td>
        <td class="team-review-note">
          {{if .Review.Body}}<span class="clamp">{{.Review.Body}}</span>{{else}}<span class="muted">—</span>{{end}}
          {{if .Review.GHCommentURL}} <a class="team-review-gh-link" href="{{.Review.GHCommentURL}}" target="_blank" rel="noopener">GH ↗</a>{{end}}
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <p class="muted team-review-empty">No team reviews yet.</p>
  {{end}}

  {{if .TeamPendingRequests}}
  <div class="team-review-block">
    <h3 class="team-review-h3">Pending requests</h3>
    <div class="table-scroll">
    <table>
      <thead><tr><th>Reviewer</th><th>From</th><th>Note</th>{{if $.CanPRReview}}<th></th>{{end}}</tr></thead>
      <tbody>
      {{range .TeamPendingRequests}}
        <tr>
          <td>{{if .ReviewerName}}{{.ReviewerName}}{{else}}<span class="mono">{{.ReviewerID}}</span>{{end}}</td>
          <td class="muted">{{if .RequesterName}}{{.RequesterName}}{{else if .RequesterID}}<span class="mono">{{.RequesterID}}</span>{{else}}—{{end}}</td>
          <td class="team-review-note">{{if .Note}}{{.Note}}{{else}}<span class="muted">—</span>{{end}}</td>
          {{if $.CanPRReview}}
          <td class="row-actions">
            <form method="post" action="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/review-requests/cancel" class="inline">
              {{template "csrf" $}}
              <input type="hidden" name="project" value="{{$.Project}}">
              <input type="hidden" name="requestId" value="{{.ID}}">
              <button type="submit" class="btn-secondary btn-compact">Cancel</button>
            </form>
          </td>
          {{end}}
        </tr>
      {{end}}
      </tbody>
    </table>
    </div>
  </div>
  {{end}}

  {{if and .CanPRReview (eq .PR.State "OPEN")}}
  <div class="team-review-actions">
    <div class="team-review-block">
      <h3 class="team-review-h3">Submit review</h3>
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/reviews" id="pr-review-form" class="team-review-form">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <input type="hidden" name="headSha" value="{{.PR.HeadSHA}}">
        <div class="team-review-fields">
          <div class="field">
            <label for="verdict">Verdict</label>
            <select id="verdict" name="verdict" required>
              <option value="approved">Approve</option>
              <option value="changes_requested">Request changes</option>
              <option value="commented">Comment only</option>
            </select>
          </div>
          <div class="field field-grow">
            <label for="review-body">Message</label>
            <textarea id="review-body" name="body" rows="3" placeholder="Optional for approve; required for request changes"></textarea>
          </div>
        </div>
        {{if .CanGitHubWrite}}
        <label class="check"><input type="checkbox" name="mirror" value="1" checked> Post summary on GitHub as a PR comment</label>
        {{end}}
        <div class="form-actions"><button type="submit" id="btn-submit-review">Submit review</button></div>
      </form>
    </div>

    {{if .ReviewerOptions}}
    <div class="team-review-block">
      <h3 class="team-review-h3">Request review</h3>
      <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/review-requests" id="pr-request-review-form" class="team-review-form">
        {{template "csrf" $}}
        <input type="hidden" name="project" value="{{.Project}}">
        <input type="hidden" name="headSha" value="{{.PR.HeadSHA}}">
        <div class="team-review-fields">
          <div class="field">
            <label for="reviewerId">Reviewer</label>
            <select id="reviewerId" name="reviewerId" required>
              <option value="">Select teammate…</option>
              {{range .ReviewerOptions}}
              <option value="{{.ID}}">{{.Name}}</option>
              {{end}}
            </select>
          </div>
          <div class="field field-grow">
            <label for="review-note">Note (optional)</label>
            <input type="text" id="review-note" name="note" placeholder="What should they focus on?">
          </div>
        </div>
        <div class="form-actions"><button type="submit" class="btn-secondary" id="btn-request-review">Request review</button></div>
      </form>
    </div>
    {{end}}
  </div>
  {{else if not .CanPRReview}}
  <p class="muted team-review-empty">Requires member role with <span class="mono">prReviews</span> enabled.</p>
  {{end}}
</div>

{{if .CanStartSession}}
<div class="section card" id="pr-address-actions">
  <h2>Grok actions</h2>
  <p class="sub">Starts or reuses a Discord work unit for this PR. Grok pushes fixes; it does not merge.</p>
  {{if .ShowFixPicker}}
  <p class="flash">Multiple sessions already bind this PR. Pick one, or force a new thread.</p>
  <div class="table-scroll">
  <table class="table">
    <thead><tr><th>Thread</th><th>Label</th><th>Goal</th><th></th></tr></thead>
    <tbody>
    {{range .FixHits}}
      <tr>
        <td class="mono">{{.ThreadID}}</td>
        <td><span class="badge">{{.Label}}</span>{{if .Busy}} <span class="badge live">busy</span>{{end}}</td>
        <td>{{.Goal}}</td>
        <td class="row-actions">
          <form method="post" action="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/address-ci" style="display:inline">
            {{template "csrf" $}}
            <input type="hidden" name="project" value="{{$.Project}}">
            <input type="hidden" name="thread_id" value="{{.ThreadID}}">
            <button type="submit" class="btn-secondary" style="height:2rem;font-size:0.82rem;">Continue (CI)</button>
          </form>
          <form method="post" action="/prs/{{$.ActiveOwner}}/{{$.ActiveRepo}}/{{$.PRNumber}}/address-review" style="display:inline">
            {{template "csrf" $}}
            <input type="hidden" name="project" value="{{$.Project}}">
            <input type="hidden" name="thread_id" value="{{.ThreadID}}">
            <button type="submit" class="btn-secondary" style="height:2rem;font-size:0.82rem;">Continue (review)</button>
          </form>
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
  </div>
  {{end}}
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/address-ci" style="margin-bottom:0.75rem;">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    <label class="check"><input type="checkbox" name="force_new" value="1"> Always start new thread</label>
    <div class="form-actions"><button type="submit" id="btn-address-ci">Address CI</button></div>
  </form>
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/address-review">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    <label class="check"><input type="checkbox" name="force_new" value="1"> Always start new thread</label>
    <div class="form-actions"><button type="submit" id="btn-address-review">Address review</button></div>
  </form>
</div>
{{end}}

{{if .CanGitHubWrite}}
<div class="section card" id="pr-comment-form">
  <h2>Add comment</h2>
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/comments">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    <label for="pr-body">Comment</label>
    <textarea id="pr-body" name="body" rows="4" required placeholder="Write a comment…"></textarea>
    <div class="form-actions"><button type="submit">Post comment</button></div>
  </form>
</div>
{{if eq .PR.State "OPEN"}}
<div class="section card" id="pr-close-form">
  <h2>Close PR</h2>
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/close" onsubmit="return confirm('Close this pull request?');">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    <div class="form-actions"><button type="submit" class="btn-danger">Close pull request</button></div>
  </form>
</div>
{{end}}
{{end}}

{{if and .CanMerge (eq .PR.State "OPEN")}}
<div class="section card" id="pr-merge-form">
  <h2>Merge PR</h2>
  <p class="sub" style="margin-top:0">Uses host <span class="mono">gh pr merge</span> with branch protection. Never passes <span class="mono">--admin</span>.</p>
  <form method="post" action="/prs/{{.ActiveOwner}}/{{.ActiveRepo}}/{{.PRNumber}}/merge" onsubmit="return confirm('Merge this pull request?');">
    {{template "csrf" $}}
    <input type="hidden" name="project" value="{{.Project}}">
    <label for="merge-method">Method</label>
    <select id="merge-method" name="method">
      <option value="squash" {{if eq .WebMergeMethod "squash"}}selected{{end}}>Squash</option>
      <option value="merge" {{if eq .WebMergeMethod "merge"}}selected{{end}}>Merge commit</option>
      <option value="rebase" {{if eq .WebMergeMethod "rebase"}}selected{{end}}>Rebase</option>
    </select>
    <label class="check"><input type="checkbox" name="attemptAnyway" value="1"> Attempt merge even if checks look failing (still no protection bypass)</label>
    <div class="form-actions"><button type="submit">Merge pull request</button></div>
  </form>
</div>
{{end}}
{{end}}
