{{define "content"}}
<div class="config-sub" id="page-config-identities">
{{template "config_sub_header" $}}
<h1>GitHub attribution</h1>

<div class="section card gh-map-card" id="github-attribution">
  <div class="gh-map-header">
    <div class="gh-map-eyebrow">Attribution · Tier A</div>
    <h2>Discord user → GitHub login</h2>
    <p class="sub" style="margin-top:0">
      Maps Discord snowflakes to GitHub profiles for ship trailers, PR footers, and web comment prefixes.
      The host bot still pushes and comments; this only records who asked.
      Unmapped users keep plain Discord attribution — no invented <span class="mono">@login</span>.
    </p>
  </div>

  <div class="gh-map-bridge" aria-hidden="true">
    <span class="gh-map-node gh-map-node-discord">Discord id</span>
    <span class="gh-map-rail"></span>
    <span class="gh-map-node gh-map-node-github">@login</span>
  </div>

  <form class="gh-map-form" method="post" action="{{route "config.setGitHubIdentity"}}" id="github-identity-form">
    {{template "csrf" $}}
    <div class="gh-map-fields">
      <div>
        <label for="gh-discord-id">Discord user ID</label>
        <input id="gh-discord-id" type="text" name="discordUserId" placeholder="123456789012345678" required autocomplete="off" spellcheck="false" inputmode="numeric" pattern="[0-9]+" title="Discord snowflake (digits only)">
      </div>
      <div>
        <label for="gh-login">GitHub login</label>
        <input id="gh-login" type="text" name="login" placeholder="alice" required autocomplete="off" spellcheck="false">
      </div>
      <div>
        <label for="gh-name">Display name <span class="muted">(optional)</span></label>
        <input id="gh-name" type="text" name="name" placeholder="Alice Example" autocomplete="name">
      </div>
      <div>
        <label for="gh-email">Email <span class="muted">(optional)</span></label>
        <input id="gh-email" type="email" name="email" placeholder="alice@users.noreply.github.com" autocomplete="off" spellcheck="false">
      </div>
    </div>
    <div class="form-actions">
      <button type="submit">Save mapping</button>
    </div>
    <p class="sub" style="margin:0.5rem 0 0">
      Saving the same Discord id updates that row. Login is required; leading <span class="mono">@</span> is stripped.
      Empty email uses GitHub’s noreply address for Co-authored-by.
    </p>
  </form>

  {{if .Config.GitHubIdentities}}
  <div class="table-scroll gh-map-table-wrap">
  <table class="gh-map-table" id="github-identity-table">
    <thead>
      <tr>
        <th>Discord user</th>
        <th>GitHub</th>
        <th>Name</th>
        <th>Email</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{range .Config.GitHubIdentities}}
      <tr>
        <td class="mono">
          {{$dn := index $.DiscordUserNames .DiscordUserID}}
          {{if $dn}}<span class="gh-map-display">{{$dn}}</span><br>{{end}}
          <span class="muted">{{.DiscordUserID}}</span>
        </td>
        <td class="mono"><span class="gh-map-login">@{{.Login}}</span></td>
        <td>{{if .Name}}{{.Name}}{{else}}<span class="muted">—</span>{{end}}</td>
        <td class="mono muted">{{if .Email}}{{.Email}}{{else}}noreply default{{end}}</td>
        <td class="row-actions">
          <form method="post" action="{{route "config.removeGitHubIdentity"}}" onsubmit="return confirm('Remove map for Discord {{.DiscordUserID}}?');">
            {{template "csrf" $}}
            <input type="hidden" name="discordUserId" value="{{.DiscordUserID}}">
            <button type="submit" class="btn-danger">Remove</button>
          </form>
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
  {{else}}
  <div class="empty gh-map-empty" id="github-identity-empty">
    No Discord users mapped yet. Add a snowflake and GitHub login so comments and ship trailers name the right person.
  </div>
  {{end}}
</div>
</div>
{{end}}
