{{define "content"}}
<p class="pr-crumb">
  <a href="/projects/{{.Project}}/linear">← Linear</a>
  <span class="crumb-sep">/</span>
  <span class="mono">{{.LinearIssue.Identifier}}</span>
</p>
<div class="pr-title-row">
  <h1 id="page-linear-detail">{{if .LinearIssue.Title}}{{.LinearIssue.Title}}{{else}}{{.LinearIssue.Identifier}}{{end}}</h1>
  <div class="pr-head-links">
    {{if .LinearIssue.URL}}<a class="btn btn-compact" href="{{.LinearIssue.URL}}" target="_blank" rel="noopener">Linear ↗</a>{{end}}
  </div>
</div>
<div class="pr-meta">
  {{if eq .LinearIssue.WorkState "FIXING"}}
  <span class="badge status-fixing" title="Active Grok fix session">FIXING</span>
  {{else if .LinearIssue.State}}
  <span class="badge">{{.LinearIssue.State}}</span>
  {{end}}
  {{if .LinearIssue.TeamKey}}<span class="mono">team {{.LinearIssue.TeamKey}}</span>{{end}}
</div>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
{{if .Error}}<div class="flash err">{{.Error}}</div>{{end}}

<div class="pr-cols">
<div class="pr-main">

<div class="section card">
  <h2>Description</h2>
  {{if .LinearIssue.Description}}<div class="md">{{markdown .LinearIssue.Description}}</div>{{else}}<p class="muted" style="margin:0">No description.</p>{{end}}
</div>

</div>{{/* /pr-main */}}

<aside class="pr-rail">

{{if and .CanStartSession .LinearEnabled}}
<div class="rail-group" id="linear-fix-form">
  <div class="rail-group-title">Grok</div>
  {{if .ShowFixPicker}}
  <p class="rail-note">Multiple sessions bind this issue — continue one:</p>
  {{range .FixHits}}
  <div class="grok-pick">
    <div class="grok-pick-head">
      <span class="badge">{{.Label}}</span>
      {{if .Busy}}<span class="badge live">busy</span>{{end}}
      <a class="tid mono" href="/sessions/{{.ThreadID}}{{if $.Project}}?project={{urlquery $.Project}}{{end}}">{{.ThreadID}}</a>
    </div>
    {{if .Goal}}<div class="grok-pick-goal">{{.Goal}}</div>{{end}}
    <form method="post" action="/projects/{{$.Project}}/linear/{{$.LinearIssue.Identifier}}/fix" class="grok-pick-actions">
      {{template "csrf" $}}
      <input type="hidden" name="thread_id" value="{{.ThreadID}}">
      <button type="submit" class="btn-secondary btn-compact">Continue</button>
    </form>
  </div>
  {{else}}
  <p class="rail-note">No candidates (they may be terminal).</p>
  {{end}}
  <p class="rail-note">Or dispatch a fresh thread:</p>
  {{end}}
  <form method="post" action="/projects/{{.Project}}/linear/{{.LinearIssue.Identifier}}/fix" class="grok-dispatch">
    {{template "csrf" $}}
    {{if .ShowFixPicker}}
    <input type="hidden" name="force_new" value="1">
    {{else}}
    <label class="check"><input type="checkbox" name="force_new" value="1"> Always start a new thread</label>
    {{end}}
    <div class="form-actions"><button type="submit" id="btn-fix-linear">Fix with Grok</button></div>
  </form>
  <p class="rail-note">Starts or reuses a Discord work unit (Fixes bind). Grok opens/updates a PR; it never merges.</p>
</div>
{{else}}
<div class="rail-group">
  <div class="rail-group-title">Actions</div>
  <p class="rail-note">Read-only access — Grok dispatch needs a member role with web features enabled.</p>
</div>
{{end}}

</aside>
</div>{{/* /pr-cols */}}
{{end}}
